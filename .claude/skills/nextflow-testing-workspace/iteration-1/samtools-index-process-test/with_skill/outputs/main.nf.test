nextflow_process {
    name "Test Process SAMTOOLS_INDEX"
    script "modules/samtools/index/main.nf"
    process "SAMTOOLS_INDEX"
    tag "samtools"
    tag "samtools_index"
    tag "modules"

    test("Should run successfully and produce a BAI index file") {
        when {
            process {
                """
                input[0] = [
                    [ id: 'test_sample', single_end: false ],
                    file("${projectDir}/tests/data/test.sorted.bam")
                ]
                """
            }
        }
        then {
            assert process.success
            assert process.out.bai.size() == 1
            assert process.out.bai[0][1].endsWith(".bai")
            assert path(process.out.bai[0][1]).exists()
            assert process.out.versions != null
        }
    }

    test("Should produce snapshot-matching output for a sorted BAM") {
        when {
            process {
                """
                input[0] = [
                    [ id: 'test_sample', single_end: false ],
                    file("${projectDir}/tests/data/test.sorted.bam")
                ]
                """
            }
        }
        then {
            assert process.success
            assert snapshot(process.out).match()
        }
    }

    test("Should preserve meta map in output channel") {
        when {
            process {
                """
                input[0] = [
                    [ id: 'meta_check', single_end: true, strandedness: 'forward' ],
                    file("${projectDir}/tests/data/test.sorted.bam")
                ]
                """
            }
        }
        then {
            assert process.success
            assert process.out.bai[0][0].id == 'meta_check'
            assert process.out.bai[0][0].single_end == true
            assert process.out.bai[0][0].strandedness == 'forward'
        }
    }
}
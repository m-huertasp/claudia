nextflow_workflow {
    name "Test Workflow RNASEQ_ALIGN"
    script "workflows/rnaseq.nf"
    workflow "RNASEQ_ALIGN"
    tag "rnaseq"
    tag "alignment"

    test("Should complete successfully with paired-end reads") {
        when {
            workflow {
                """
                input[0] = Channel.of(
                    [ [id: 'sample1', single_end: false],
                      [ file("${projectDir}/tests/data/sample1_R1.fastq.gz"),
                        file("${projectDir}/tests/data/sample1_R2.fastq.gz") ] ]
                )
                input[1] = file("${projectDir}/tests/data/star_index")
                """
            }
        }
        then {
            assert workflow.success
        }
    }

    test("Should emit the correct number of BAM files") {
        when {
            workflow {
                """
                input[0] = Channel.of(
                    [ [id: 'sample1', single_end: false],
                      [ file("${projectDir}/tests/data/sample1_R1.fastq.gz"),
                        file("${projectDir}/tests/data/sample1_R2.fastq.gz") ] ],
                    [ [id: 'sample2', single_end: false],
                      [ file("${projectDir}/tests/data/sample2_R1.fastq.gz"),
                        file("${projectDir}/tests/data/sample2_R2.fastq.gz") ] ]
                )
                input[1] = file("${projectDir}/tests/data/star_index")
                """
            }
        }
        then {
            assert workflow.success
            assert workflow.out.bam.size() == 2
            assert workflow.out.versions != null
            assert snapshot(workflow.out.bam).match("bam_outputs")
        }
    }

    test("Should run the correct number of tasks") {
        when {
            workflow {
                """
                input[0] = Channel.of(
                    [ [id: 'sample1', single_end: false],
                      [ file("${projectDir}/tests/data/sample1_R1.fastq.gz"),
                        file("${projectDir}/tests/data/sample1_R2.fastq.gz") ] ]
                )
                input[1] = file("${projectDir}/tests/data/star_index")
                """
            }
        }
        then {
            assert workflow.success
            // RNASEQ_ALIGN runs STAR_ALIGN + SAMTOOLS_SORT = 2 tasks per sample
            assert workflow.trace.tasks().size() == 2
            assert workflow.trace.succeeded().size() == 2
        }
    }
}
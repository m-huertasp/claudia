nextflow_workflow {
    name "Test Workflow RNASEQ_ALIGN"
    script "workflows/rnaseq.nf"
    workflow "RNASEQ_ALIGN"
    tag "rnaseq"
    tag "alignment"

    test("Should emit sorted BAM for each sample and run STAR_ALIGN and SAMTOOLS_SORT") {
        when {
            workflow {
                """
                input[0] = Channel.of(
                    [ [id: 'sample1', single_end: false],
                      [ file("${projectDir}/tests/data/sample1_R1.fastq.gz"),
                        file("${projectDir}/tests/data/sample1_R2.fastq.gz") ] ]
                )
                input[1] = file("${projectDir}/tests/data/star_index")
                """
            }
        }
        then {
            assert workflow.success
            assert workflow.out.bam.size() == 1
            assert workflow.trace.tasks().size() == 2
            assert snapshot(workflow.out.bam).match("bam_channel")
            assert snapshot(workflow.out.versions).match("versions_channel")
        }
    }

    test("Should emit one BAM per sample when given multiple samples") {
        when {
            workflow {
                """
                input[0] = Channel.of(
                    [ [id: 'sample1', single_end: false],
                      [ file("${projectDir}/tests/data/sample1_R1.fastq.gz"),
                        file("${projectDir}/tests/data/sample1_R2.fastq.gz") ] ],
                    [ [id: 'sample2', single_end: false],
                      [ file("${projectDir}/tests/data/sample2_R1.fastq.gz"),
                        file("${projectDir}/tests/data/sample2_R2.fastq.gz") ] ]
                )
                input[1] = file("${projectDir}/tests/data/star_index")
                """
            }
        }
        then {
            assert workflow.success
            assert workflow.out.bam.size() == 2
            assert workflow.trace.tasks().size() == 4   // STAR_ALIGN + SAMTOOLS_SORT per sample
            assert snapshot(workflow.out.bam).match("bam_channel_two_samples")
        }
    }
}
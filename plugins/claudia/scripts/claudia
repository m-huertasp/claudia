#!/usr/bin/env python3
"""claudia — tiny deterministic skeleton for the claudia plugin.

Subcommands:
  detect        report the primary project type (python / nextflow / mixed / unknown)
  config        read or write .planning/config.json (init | get | set)
  env capture   probe local tool versions; optionally rewrite the
                ## Environment section of .planning/CONTEXT.md
  rules inject  (added in step 6) inject the Claudia Rules section into CLAUDE.md

All commands emit a JSON envelope on stdout:
  success: {"ok": true, "data": <...>}
  failure: {"ok": false, "error": "<message>"}
Use --text on commands that support it for a human-readable rendering instead.
"""

from __future__ import annotations

import argparse
import json
import subprocess
import sys
from dataclasses import asdict, dataclass, field
from datetime import datetime, timezone
from pathlib import Path
from typing import Any

# ---------------------------------------------------------------------------
# detect
# ---------------------------------------------------------------------------

PYTHON = "python"
NEXTFLOW = "nextflow"
MIXED = "mixed"
UNKNOWN = "unknown"

_PYTHON_MARKERS = ("pyproject.toml", "setup.py", "requirements.txt")
_NEXTFLOW_MARKERS = ("main.nf", "nextflow.config")
_NEXTFLOW_SUBDIRS = ("modules", "workflows", "subworkflows")


@dataclass(frozen=True)
class Detection:
    type: str
    languages: list[str] = field(default_factory=list)
    evidence: dict[str, list[str]] = field(default_factory=dict)


def _python_evidence(root: Path) -> list[str]:
    return [name for name in _PYTHON_MARKERS if (root / name).is_file()]


def _nextflow_evidence(root: Path) -> list[str]:
    found = [name for name in _NEXTFLOW_MARKERS if (root / name).is_file()]
    for subdir in _NEXTFLOW_SUBDIRS:
        path = root / subdir
        if not path.is_dir():
            continue
        for nf_file in sorted(path.rglob("*.nf")):
            found.append(str(nf_file.relative_to(root)))
            break
    return found


def detect_project(root: Path) -> Detection:
    nf = _nextflow_evidence(root)
    py = _python_evidence(root)
    evidence: dict[str, list[str]] = {}
    if nf:
        evidence[NEXTFLOW] = nf
    if py:
        evidence[PYTHON] = py
    languages = list(evidence.keys())
    if nf and py:
        return Detection(type=MIXED, languages=languages, evidence=evidence)
    if nf:
        return Detection(type=NEXTFLOW, languages=languages, evidence=evidence)
    if py:
        return Detection(type=PYTHON, languages=languages, evidence=evidence)
    return Detection(type=UNKNOWN, languages=[], evidence={})


# ---------------------------------------------------------------------------
# config
# ---------------------------------------------------------------------------

DEFAULT_CONFIG: dict[str, Any] = {
    "mode": "pair",
    "agents": {
        "domain_reviewer": False,
        "nextflow_reviewer": True,
    },
}

_CONFIG_ENUMS: dict[str, set[str]] = {"mode": {"pair", "yolo"}}
_CONFIG_BOOLS: frozenset[str] = frozenset({"agents.domain_reviewer", "agents.nextflow_reviewer"})
_CONFIG_KEYS: frozenset[str] = frozenset(_CONFIG_ENUMS) | _CONFIG_BOOLS


def config_path(root: Path) -> Path:
    return root / ".planning" / "config.json"


def config_init(root: Path, force: bool = False) -> Path:
    target = config_path(root)
    if target.exists() and not force:
        raise SystemExit(f"config already exists at {target}; pass --force to overwrite")
    target.parent.mkdir(parents=True, exist_ok=True)
    target.write_text(json.dumps(DEFAULT_CONFIG, indent=2) + "\n", encoding="utf-8")
    return target


def config_read(root: Path) -> dict[str, Any]:
    target = config_path(root)
    if not target.exists():
        raise SystemExit(f"no config at {target} — run `claudia config init` first")
    try:
        return json.loads(target.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        raise SystemExit(f"invalid JSON in {target}: {exc}") from exc


def config_get(root: Path, key: str) -> Any:
    if key not in _CONFIG_KEYS:
        raise SystemExit(f"unknown config key '{key}' (allowed: {sorted(_CONFIG_KEYS)})")
    node: Any = config_read(root)
    for part in key.split("."):
        if not isinstance(node, dict) or part not in node:
            raise SystemExit(f"config key '{key}' is not set")
        node = node[part]
    return node


def _coerce_config_value(key: str, value: str) -> Any:
    if key in _CONFIG_BOOLS:
        lowered = value.strip().lower()
        if lowered in {"true", "false"}:
            return lowered == "true"
        raise SystemExit(f"'{key}' must be true or false, got '{value}'")
    if key in _CONFIG_ENUMS:
        if value in _CONFIG_ENUMS[key]:
            return value
        raise SystemExit(f"'{key}' must be one of {sorted(_CONFIG_ENUMS[key])}, got '{value}'")
    raise SystemExit(f"unknown config key '{key}'")


def config_set(root: Path, key: str, value: str) -> dict[str, Any]:
    if key not in _CONFIG_KEYS:
        raise SystemExit(f"unknown config key '{key}' (allowed: {sorted(_CONFIG_KEYS)})")
    coerced = _coerce_config_value(key, value)
    config = config_read(root)
    parts = key.split(".")
    node = config
    for part in parts[:-1]:
        node = node.setdefault(part, {})
    node[parts[-1]] = coerced
    target = config_path(root)
    target.write_text(json.dumps(config, indent=2) + "\n", encoding="utf-8")
    return config


# ---------------------------------------------------------------------------
# env capture
# ---------------------------------------------------------------------------

_PROBE_TIMEOUT_SECONDS = 5

DEFAULT_PROBES: dict[str, tuple[str, ...]] = {
    "python":      ("python3",     "--version"),
    "uv":          ("uv",          "--version"),
    "conda":       ("conda",       "--version"),
    "mamba":       ("mamba",       "--version"),
    "nextflow":    ("nextflow",    "-version"),
    "nf-test":     ("nf-test",     "--version"),
    "docker":      ("docker",      "--version"),
    "singularity": ("singularity", "--version"),
    "apptainer":   ("apptainer",   "--version"),
    "pytest":      ("pytest",      "--version"),
    "ruff":        ("ruff",        "--version"),
    "mypy":        ("mypy",        "--version"),
}

ENV_SECTION_START = "<!-- claudia:env:start -->"
ENV_SECTION_END = "<!-- claudia:env:end -->"


@dataclass(frozen=True)
class ToolVersion:
    name: str
    version: str | None
    command: str


@dataclass(frozen=True)
class Environment:
    project: Detection
    tools: list[ToolVersion]
    captured_at: str


def _probe(cmd: tuple[str, ...]) -> str | None:
    try:
        result = subprocess.run(
            cmd, capture_output=True, text=True,
            timeout=_PROBE_TIMEOUT_SECONDS, check=False,
        )
    except (FileNotFoundError, subprocess.TimeoutExpired):
        return None
    if result.returncode != 0:
        return None
    output = (result.stdout or result.stderr).strip()
    return output.splitlines()[0] if output else None


def capture_environment(root: Path) -> Environment:
    tools = [
        ToolVersion(name=name, version=_probe(cmd), command=" ".join(cmd))
        for name, cmd in DEFAULT_PROBES.items()
    ]
    return Environment(
        project=detect_project(root),
        tools=tools,
        captured_at=datetime.now(timezone.utc).isoformat(timespec="seconds"),
    )


def _render_env_section(env: Environment) -> str:
    lines = [
        "## Environment",
        "",
        ENV_SECTION_START,
        f"_Captured: {env.captured_at}_",
        "",
        f"**Project type:** {env.project.type}",
    ]
    if env.project.languages:
        lines.append(f"**Languages:** {', '.join(env.project.languages)}")
    lines.extend(["", "**Tools:**", ""])
    for tool in env.tools:
        version = tool.version if tool.version is not None else "_not installed_"
        lines.append(f"- `{tool.name}` — {version}")
    lines.append("")
    lines.append(ENV_SECTION_END)
    return "\n".join(lines) + "\n"


def write_env_section(root: Path, env: Environment) -> Path:
    """Replace (or append) the `## Environment` section in .planning/CONTEXT.md."""
    context_path = root / ".planning" / "CONTEXT.md"
    context_path.parent.mkdir(parents=True, exist_ok=True)
    new_section = _render_env_section(env)
    if not context_path.exists():
        context_path.write_text(f"# Project context\n\n{new_section}", encoding="utf-8")
        return context_path
    existing = context_path.read_text(encoding="utf-8")
    if ENV_SECTION_START in existing and ENV_SECTION_END in existing:
        start = existing.index("## Environment")
        end_marker = existing.index(ENV_SECTION_END) + len(ENV_SECTION_END)
        # consume trailing newline after marker if present
        if end_marker < len(existing) and existing[end_marker] == "\n":
            end_marker += 1
        rebuilt = existing[:start] + new_section + existing[end_marker:]
    else:
        sep = "" if existing.endswith("\n") else "\n"
        rebuilt = existing + sep + "\n" + new_section
    context_path.write_text(rebuilt, encoding="utf-8")
    return context_path


# ---------------------------------------------------------------------------
# rules inject
# ---------------------------------------------------------------------------

RULES_SECTION_START = "<!-- claudia:rules:start -->"
RULES_SECTION_END = "<!-- claudia:rules:end -->"
RULES_SECTION_HEADING = "## Claudia Rules"

_PLUGIN_ROOT = Path(__file__).resolve().parent.parent  # plugins/claudia/
_RULES_DIR_NAME = "rules"


def _project_rule_subsets(project_type: str) -> list[str]:
    """Return the rule subdirectory names to include for a project type."""
    subsets = ["common"]
    if project_type in {PYTHON, MIXED}:
        subsets.append("python")
    if project_type in {NEXTFLOW, MIXED}:
        subsets.append("nextflow")
    return subsets


def _collect_rule_files(project_type: str) -> list[tuple[str, str]]:
    """Return [(subset, filename), ...] for every rule file applicable to project_type.

    Skips subsets that don't exist on disk so the script never points at missing
    files (e.g. the plugin has no `rules/nextflow/` today).
    """
    rules_dir = _PLUGIN_ROOT / _RULES_DIR_NAME
    collected: list[tuple[str, str]] = []
    for subset in _project_rule_subsets(project_type):
        subset_dir = rules_dir / subset
        if not subset_dir.is_dir():
            continue
        for md in sorted(subset_dir.glob("*.md")):
            collected.append((subset, md.name))
    return collected


def _render_rules_section(project_type: str) -> str:
    files = _collect_rule_files(project_type)
    lines = [
        RULES_SECTION_HEADING,
        "",
        RULES_SECTION_START,
        "_Auto-generated by `claudia rules inject` — do not edit by hand. "
        f"Detected project type: `{project_type}`._",
        "",
    ]
    for subset, name in files:
        lines.append(f"@${{CLAUDE_PLUGIN_ROOT}}/{_RULES_DIR_NAME}/{subset}/{name}")
    lines.append("")
    lines.append(RULES_SECTION_END)
    return "\n".join(lines) + "\n"


def inject_rules(root: Path, target: Path | None = None, dry_run: bool = False) -> dict[str, Any]:
    """Inject the `## Claudia Rules` section into the project's CLAUDE.md.

    Idempotent: re-running replaces the sentinel-bounded block in place. If
    `target` is None, defaults to `<root>/CLAUDE.md`. If `dry_run` is True,
    returns the would-be new content without writing.
    """
    claude_md = target if target is not None else root / "CLAUDE.md"
    detection = detect_project(root)
    new_section = _render_rules_section(detection.type)

    if not claude_md.exists():
        new_content = f"# Project instructions\n\n{new_section}"
        action = "create"
    else:
        existing = claude_md.read_text(encoding="utf-8")
        if RULES_SECTION_START in existing and RULES_SECTION_END in existing:
            start = existing.index(RULES_SECTION_HEADING)
            end_marker = existing.index(RULES_SECTION_END) + len(RULES_SECTION_END)
            if end_marker < len(existing) and existing[end_marker] == "\n":
                end_marker += 1
            new_content = existing[:start] + new_section + existing[end_marker:]
            action = "replace"
        else:
            sep = "" if existing.endswith("\n") else "\n"
            new_content = existing + sep + "\n" + new_section
            action = "append"

    rule_count = new_section.count("@${CLAUDE_PLUGIN_ROOT}")
    result: dict[str, Any] = {
        "path": str(claude_md),
        "action": action,
        "project_type": detection.type,
        "rule_count": rule_count,
        "dry_run": dry_run,
    }
    if dry_run:
        result["preview"] = new_section
        return result
    claude_md.parent.mkdir(parents=True, exist_ok=True)
    claude_md.write_text(new_content, encoding="utf-8")
    return result


# ---------------------------------------------------------------------------
# output helpers
# ---------------------------------------------------------------------------

def emit_ok(data: Any, text_form: str | None = None, use_text: bool = False) -> None:
    if use_text and text_form is not None:
        print(text_form)
        return
    print(json.dumps({"ok": True, "data": data}, indent=2, default=_default_json))


def _default_json(obj: Any) -> Any:
    if hasattr(obj, "__dict__"):
        return obj.__dict__
    raise TypeError(f"not serialisable: {type(obj).__name__}")


def _detection_to_dict(d: Detection) -> dict[str, Any]:
    return {"type": d.type, "languages": d.languages, "evidence": d.evidence}


def _env_to_dict(e: Environment) -> dict[str, Any]:
    return {
        "project": _detection_to_dict(e.project),
        "tools": [asdict(t) for t in e.tools],
        "captured_at": e.captured_at,
    }


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------

def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="claudia", description="claudia plugin skeleton")
    sub = parser.add_subparsers(dest="cmd", required=True)

    # detect
    p_detect = sub.add_parser("detect", help="report primary project type")
    p_detect.add_argument("--root", type=Path, default=Path.cwd())
    p_detect.add_argument("--text", action="store_true")

    # config
    p_config = sub.add_parser("config", help="read or write .planning/config.json")
    config_sub = p_config.add_subparsers(dest="config_cmd", required=True)
    p_init = config_sub.add_parser("init")
    p_init.add_argument("--root", type=Path, default=Path.cwd())
    p_init.add_argument("--force", action="store_true")
    p_get = config_sub.add_parser("get")
    p_get.add_argument("key")
    p_get.add_argument("--root", type=Path, default=Path.cwd())
    p_set = config_sub.add_parser("set")
    p_set.add_argument("key")
    p_set.add_argument("value")
    p_set.add_argument("--root", type=Path, default=Path.cwd())

    # env
    p_env = sub.add_parser("env", help="environment helpers")
    env_sub = p_env.add_subparsers(dest="env_cmd", required=True)
    p_capture = env_sub.add_parser("capture")
    p_capture.add_argument("--root", type=Path, default=Path.cwd())
    p_capture.add_argument("--section", action="store_true",
                           help="rewrite the ## Environment section of .planning/CONTEXT.md")
    p_capture.add_argument("--text", action="store_true")

    # rules
    p_rules = sub.add_parser("rules", help="inject claudia rules into CLAUDE.md")
    rules_sub = p_rules.add_subparsers(dest="rules_cmd", required=True)
    p_inject = rules_sub.add_parser("inject")
    p_inject.add_argument("--root", type=Path, default=Path.cwd())
    p_inject.add_argument("--path", type=Path, default=None,
                          help="target CLAUDE.md path (defaults to <root>/CLAUDE.md)")
    p_inject.add_argument("--dry-run", action="store_true",
                          help="preview the section without writing")

    return parser


def cmd_detect(args: argparse.Namespace) -> None:
    detection = detect_project(args.root)
    text = f"project type: {detection.type}"
    if detection.languages:
        text += f"\nlanguages: {', '.join(detection.languages)}"
    emit_ok(_detection_to_dict(detection), text_form=text, use_text=args.text)


def cmd_config(args: argparse.Namespace) -> None:
    if args.config_cmd == "init":
        path = config_init(args.root, force=args.force)
        emit_ok({"path": str(path)})
    elif args.config_cmd == "get":
        value = config_get(args.root, args.key)
        emit_ok({"key": args.key, "value": value})
    elif args.config_cmd == "set":
        config = config_set(args.root, args.key, args.value)
        emit_ok({"key": args.key, "config": config})


def cmd_env(args: argparse.Namespace) -> None:
    env = capture_environment(args.root)
    if args.section:
        path = write_env_section(args.root, env)
        emit_ok({"path": str(path), "tools_probed": len(env.tools)})
        return
    text_lines = [f"captured: {env.captured_at}",
                  f"project: {env.project.type}",
                  "tools:"]
    for tool in env.tools:
        text_lines.append(f"  {tool.name}: {tool.version or 'not installed'}")
    emit_ok(_env_to_dict(env), text_form="\n".join(text_lines), use_text=args.text)


def cmd_rules(args: argparse.Namespace) -> None:
    result = inject_rules(args.root, target=args.path, dry_run=args.dry_run)
    emit_ok(result)


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    try:
        if args.cmd == "detect":
            cmd_detect(args)
        elif args.cmd == "config":
            cmd_config(args)
        elif args.cmd == "env":
            cmd_env(args)
        elif args.cmd == "rules":
            cmd_rules(args)
        else:
            parser.error(f"unknown command: {args.cmd}")
    except SystemExit as exc:
        message = str(exc) if exc.args else "error"
        print(json.dumps({"ok": False, "error": message}, indent=2), file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    sys.exit(main())
